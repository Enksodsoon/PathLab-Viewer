{
	email {$ACME_EMAIL}
	metrics
}

{$DOMAIN} {
	encode zstd gzip

	@uploads path /api/v1/uploads/*
	handle @uploads {
		header Cache-Control "no-store"
		reverse_proxy tusd:8080
	}

	@backend path /api/* /livez /readyz
	handle @backend {
		header Cache-Control "no-store"
		reverse_proxy api:8000
	}

	handle_path /tiles/* {
		root * /pathlab-data/public
		header Cache-Control "public, max-age=31536000, s-maxage=60, immutable"
		header X-Content-Type-Options "nosniff"
		file_server
	}

	handle /assets/* {
		root * /srv
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	header /s/* X-Robots-Tag "noindex, nofollow, noarchive"
	header /f/* X-Robots-Tag "noindex, nofollow, noarchive"
	header {
		Referrer-Policy "no-referrer"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		-Server
	}

	handle {
		root * /srv
		header Cache-Control "no-cache"
		try_files {path} /index.html
		file_server
	}
}
