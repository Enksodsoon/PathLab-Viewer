FROM python:3.14.6-slim-bookworm@sha256:86f975aca15cf04a40b399eebede9aea7c82eae084d1f1a0a6ef6bcaae871a30

ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl libvips42 libvips-tools \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY pyproject.toml README.md alembic.ini ./
COPY deploy/backend-requirements.txt ./deploy/backend-requirements.txt
COPY migrations ./migrations
COPY server ./server
RUN pip install --no-cache-dir --require-hashes -r deploy/backend-requirements.txt \
    && pip install --no-cache-dir --no-deps .
RUN useradd --system --uid 10001 --create-home pathlab
USER pathlab
EXPOSE 8000
CMD ["uvicorn", "wsi_viewer.main:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "2", "--proxy-headers", "--forwarded-allow-ips=*"]
