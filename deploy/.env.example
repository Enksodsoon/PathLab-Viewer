DOMAIN=your-subdomain.duckdns.org
ACME_EMAIL=you@example.com
PATHLAB_SECRET_KEY=generate-with-openssl-rand-hex-32
PATHLAB_DATA_DIR=/srv/pathlab/data
PATHLAB_LIBVIPS_CONCURRENCY=1
PATHLAB_LIBVIPS_CACHE_MAX_MEM_BYTES=268435456
PATHLAB_LIBVIPS_CACHE_MAX_FILES=128
PATHLAB_LIBVIPS_CACHE_MAX_OPERATIONS=100
DUCKDNS_SUBDOMAIN=your-subdomain
DUCKDNS_TOKEN=replace-me
